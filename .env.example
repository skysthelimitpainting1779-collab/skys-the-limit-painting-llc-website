# Formspree Form ID (used for 1-3 star review intercepts)
FORMSPREE_FORM_ID=xanybvkd

# Public Production URL of the site
SITE_URL=https://www.skysthelimitpaintingllc.com

# Google Analytics Measurement ID
GA_MEASUREMENT_ID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://ouykfhoxlrkjgscdjjqg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Directus CMS — self-hosted / Docker local (NOT free Vercel Fluid hobby).
# docker compose up -d  →  http://localhost:8055
# See docs/DIRECTUS_AND_PORTAL.md and .env.directus
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055
# Optional server-only static token if public role is closed:
# DIRECTUS_TOKEN=

# Portal OAuth (Supabase Auth providers: Google and/or GitHub)
# Enable in Supabase Dashboard → Authentication → Providers
# Redirect allow-list: {SITE_URL}/auth/callback
# NEXT_PUBLIC_SITE_URL used for OAuth redirect origin in some setups
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (transactional email for lead notifications)
RESEND_API_KEY=

# secret used to authenticate Vercel Cron invocations of /api/cron/*
CRON_SECRET=

# Cal.com booking (enables the scheduling section on /estimate).
# Set to your Cal.com path, e.g. "skys-the-limit/estimate". Leave blank to hide
# the booking section entirely.
NEXT_PUBLIC_CALCOM_LINK=

# Feature flags (optional overrides): "1"/"true"/"on" or "0"/"false"/"off".
# calBooking defaults ON, but the /estimate section still only renders when
# NEXT_PUBLIC_CALCOM_LINK is set. Set to 0 to force-disable it.
NEXT_PUBLIC_FLAG_CAL_BOOKING=

# ---------------------------------------------------------------------------
# Agent OS control plane (Turso / libSQL)
# ---------------------------------------------------------------------------
# When TURSO_DATABASE_URL is set, Agent OS dual-writes hub state to Turso and
# keeps a local mirror at .agents/hub_db.json.
#
# Remote Turso:
#   TURSO_DATABASE_URL=libsql://your-db-your-org.turso.io
#   TURSO_AUTH_TOKEN=...
#
# Local file libSQL (no token, great for offline/CI):
#   TURSO_DATABASE_URL=file:./.agents/agent-os.db
#
# Force backend: auto (default) | turso | json
# AGENT_OS_STORE=auto
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
AGENT_OS_STORE=auto
