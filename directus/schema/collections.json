{
  "version": 1,
  "description": "Seed model for Directus collections consumed by src/lib/directus/client.ts",
  "collections": [
    {
      "collection": "case_studies",
      "meta": { "singleton": false, "accountability": "all" },
      "schema": { "name": "case_studies" },
      "fields": [
        { "field": "id", "type": "integer", "schema": { "is_primary_key": true, "has_auto_increment": true } },
        { "field": "status", "type": "string", "meta": { "interface": "select-dropdown", "options": { "choices": [{ "text": "Draft", "value": "draft" }, { "text": "Published", "value": "published" }, { "text": "Archived", "value": "archived" }] } } },
        { "field": "sort", "type": "integer" },
        { "field": "type", "type": "string" },
        { "field": "location", "type": "string" },
        { "field": "problem", "type": "text" },
        { "field": "prep", "type": "json" },
        { "field": "result", "type": "text" },
        { "field": "image", "type": "uuid", "meta": { "interface": "file-image" } },
        { "field": "before_image", "type": "uuid", "meta": { "interface": "file-image" } },
        { "field": "after_image", "type": "uuid", "meta": { "interface": "file-image" } },
        { "field": "market", "type": "string" }
      ]
    },
    {
      "collection": "markets",
      "meta": { "singleton": false },
      "schema": { "name": "markets" },
      "fields": [
        { "field": "id", "type": "integer", "schema": { "is_primary_key": true, "has_auto_increment": true } },
        { "field": "status", "type": "string" },
        { "field": "sort", "type": "integer" },
        { "field": "slug", "type": "string" },
        { "field": "nav_label", "type": "string" },
        { "field": "number", "type": "string" },
        { "field": "title", "type": "string" },
        { "field": "headline", "type": "string" },
        { "field": "summary", "type": "text" },
        { "field": "description", "type": "text" },
        { "field": "image", "type": "uuid" },
        { "field": "hero_image", "type": "uuid" },
        { "field": "accent", "type": "string" },
        { "field": "proof", "type": "json" },
        { "field": "capabilities", "type": "json" },
        { "field": "process", "type": "json" },
        { "field": "cta", "type": "string" },
        { "field": "meta_title", "type": "string" },
        { "field": "meta_description", "type": "string" }
      ]
    },
    {
      "collection": "site_config",
      "meta": { "singleton": true },
      "schema": { "name": "site_config" },
      "fields": [
        { "field": "id", "type": "integer", "schema": { "is_primary_key": true, "has_auto_increment": true } },
        { "field": "site_title", "type": "string" },
        { "field": "tagline", "type": "string" },
        { "field": "phone", "type": "string" },
        { "field": "email", "type": "string" },
        { "field": "address", "type": "string" },
        { "field": "mn_contractor_id", "type": "string" },
        { "field": "naics_code", "type": "string" },
        { "field": "social_facebook", "type": "string" },
        { "field": "social_instagram", "type": "string" },
        { "field": "social_linkedin", "type": "string" },
        { "field": "social_google", "type": "string" },
        { "field": "cta_headline", "type": "string" },
        { "field": "cta_body", "type": "text" },
        { "field": "announcement_bar", "type": "string" },
        { "field": "announcement_active", "type": "boolean" }
      ]
    }
  ],
  "public_permissions_note": "Grant Public role read access to published case_studies, markets, and site_config for the Next.js client (no auth token)."
}
