{
  "name": "skys-the-limit-painting-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev --port=3000 --hostname=0.0.0.0",
    "build": "next build",
    "postbuild": "node scripts/generate-sitemap.js",
    "preview": "next start",
    "clean": "node -e \"import('node:fs').then(({ rmSync }) => { rmSync('dist', { recursive: true, force: true }); rmSync('.next', { recursive: true, force: true }); })\"",
    "prepare": "git config core.hooksPath .husky 2>/dev/null || true",
    "lint": "node scripts/enforce-git.js && node scripts/verify-react-versions.mjs && tsc --noEmit",
    "lint:md": "markdownlint \"**/*.md\" --ignore \"**/node_modules/**\" --ignore \"wiki/**\" --ignore \".agents/wiki/**\" --ignore \"graphify-out/**\" --ignore \"**/.agents/wiki/**\"",
    "compile": "node scripts/compile.js",
    "ci": "node scripts/ci_check.js",
    "test": "node --test tests/*.mjs",
    "ops:harness": "node scripts/harness-ops.js",
    "ops:cron": "node scripts/cron-ops.js",
    "ops:cron:watch": "node scripts/cron-ops.js --watch",
    "ops:mock": "node scripts/harness-ops.js mock-test",
    "memory:query": "node scripts/memory-harness.js query",
    "memory:stats": "node scripts/memory-harness.js stats",
    "memory:node": "node scripts/memory-harness.js node",
    "arch:sweep": "node scripts/harness-custodian.js",
    "arch:watch": "node scripts/cron-custodian.js --watch",
    "arch:force": "node scripts/cron-custodian.js --force",
    "remotion:studio": "remotion studio remotion/index.ts",
    "render:hero": "remotion render remotion/index.ts HeroCinematic public/videos/sky-hero-cinematic.mp4 --codec=h264 --crf=20 --muted",
    "render:markets": "remotion render remotion/index.ts ResidentialLoop public/videos/sky-residential-loop.mp4 --codec=h264 --crf=22 --muted && remotion render remotion/index.ts CommercialLoop public/videos/sky-commercial-loop.mp4 --codec=h264 --crf=22 --muted && remotion render remotion/index.ts PublicSectorLoop public/videos/sky-public-sector-loop.mp4 --codec=h264 --crf=22 --muted"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@directus/sdk": "^22.0.0",
    "@phosphor-icons/react": "2.1.10",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.2",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "leaflet": "1.9.4",
    "lucide-react": "^1.22.0",
    "motion": "12.42.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.0",
    "react-wrap-balancer": "^1.1.1",
    "resend": "6.16.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.484",
    "@tailwindcss/postcss": "4.3.1",
    "@types/express": "5.0.6",
    "@types/leaflet": "1.9.21",
    "@types/node": "26.0.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.2",
    "gray-matter": "^4.0.3",
    "jsdom": "29.1.1",
    "markdownlint-cli": "^0.49.0",
    "pg": "8.22.0",
    "postcss": "8.5.16",
    "remotion": "4.0.484",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "overrides": {
    "source-map": "0.7.6",
    "js-yaml": ">=4.1.2",
    "tar": ">=7.5.16",
    "postcss": "8.5.16",
    "undici": ">=6.27.0",
    "ws": ">=8.21.0",
    "minimatch": ">=10.2.3",
    "ajv": ">=8.18.0",
    "smol-toml": ">=1.6.1",
    "srvx": ">=0.11.13",
    "@tootallnate/once": ">=2.0.1",
    "esbuild": ">=0.28.1",
    "path-to-regexp": "8.4.2",
    "path-to-regexp-updated": "npm:path-to-regexp@8.4.2",
    "express": {
      "path-to-regexp": "0.1.13"
    }
  }
}
