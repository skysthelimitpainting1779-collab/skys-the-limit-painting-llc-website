{
  "id": "ci-devops",
  "name": "CI/CD & DevOps Agent",
  "version": "2.0.0",
  "jurisdiction": {
    "allow_globs": [
      ".github/**",
      ".husky/**",
      "vercel.json",
      "knip.json",
      ".markdownlint*",
      "scripts/ci*",
      "scripts/pr-*.mjs",
      "scripts/normalize-branch*",
      "scripts/verify-vercel*",
      "scripts/enforce-*.js",
      "scripts/compile.js",
      "package.json"
    ],
    "deny_globs": [
      "src/**",
      "backend/**"
    ]
  },
  "mcps": [
    "github",
    "vercel"
  ],
  "skills": [
    "deployments-cicd",
    "env-vars",
    "vercel-cli"
  ],
  "learnings": ".agents/domains/ci-devops/learnings",
  "state_file": "state.json",
  "errors_file": "learnings/errors.json",
  "successes_file": "learnings/successes.json",
  "turso_tables": [
    "domain_agent_state",
    "domain_events"
  ]
}