{
  "id": "frontend-vercel",
  "name": "Frontend Vercel Agent",
  "version": "2.0.0",
  "jurisdiction": {
    "allow_globs": [
      "src/app/**",
      "src/lib/**",
      "src/views/**",
      "src/data/**",
      "src/assets/**",
      "next.config.*",
      "tsconfig*.json",
      "postcss.config.*",
      "components.json"
    ],
    "deny_globs": [
      "src/components/ui/**",
      "src/app/api/**",
      ".github/**",
      ".agents/**",
      "scripts/**"
    ]
  },
  "mcps": [
    "vercel",
    "chrome-devtools"
  ],
  "skills": [
    "vercel-react-best-practices",
    "vercel-composition-patterns",
    "next-cache-components"
  ],
  "learnings": ".agents/domains/frontend-vercel/learnings",
  "state_file": "state.json",
  "errors_file": "learnings/errors.json",
  "successes_file": "learnings/successes.json",
  "turso_tables": [
    "domain_agent_state",
    "domain_events"
  ]
}