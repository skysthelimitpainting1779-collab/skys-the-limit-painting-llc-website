{
  "version": "2.0.0",
  "updated_at": "2026-07-09",
  "description": "Domain agents: one folder = one specialist. Only that agent may write its jurisdiction. Each has rules, MCPs, skills, system prompt, and isolated learnings.",
  "orchestrator": {
    "id": "orchestrator",
    "role": "Routes work to domain agents. Does not implement product code. Loads kernel + this registry only."
  },
  "agents": [
    {
      "id": "frontend-vercel",
      "name": "Frontend Vercel Agent",
      "path": ".agents/domains/frontend-vercel",
      "jurisdiction": {
        "allow_globs": [
          "src/app/**",
          "src/lib/**",
          "src/views/**",
          "src/data/**",
          "src/assets/**",
          "next.config.*",
          "tsconfig*.json",
          "postcss.config.*",
          "components.json"
        ],
        "deny_globs": [
          "src/components/ui/**",
          "src/app/api/**",
          ".github/**",
          ".agents/**",
          "scripts/**"
        ]
      },
      "mcps": ["vercel", "chrome-devtools"],
      "skills": ["vercel-react-best-practices", "vercel-composition-patterns", "next-cache-components"],
      "learnings": ".agents/domains/frontend-vercel/learnings"
    },
    {
      "id": "ui-ux",
      "name": "UI/UX Design System Agent",
      "path": ".agents/domains/ui-ux",
      "jurisdiction": {
        "allow_globs": [
          "src/components/ui/**",
          "src/components/animations/**",
          "src/components/*Cursor*",
          "src/components/*Transition*",
          "src/app/globals.css",
          "src/index.css",
          "tailwind*"
        ],
        "deny_globs": [
          "src/app/api/**",
          ".github/**",
          "scripts/**",
          ".agents/domains/!(ui-ux)/**"
        ]
      },
      "mcps": [],
      "skills": ["impeccable", "high-end-visual-design", "industrial-brutalist-ui", "shadcn"],
      "learnings": ".agents/domains/ui-ux/learnings"
    },
    {
      "id": "api",
      "name": "API Routes Agent",
      "path": ".agents/domains/api",
      "jurisdiction": {
        "allow_globs": [
          "src/app/api/**",
          "backend/**",
          "src/lib/*supabase*",
          "src/lib/*db*",
          "src/lib/*lead*"
        ],
        "deny_globs": [
          "src/components/**",
          "src/views/**",
          ".github/**"
        ]
      },
      "mcps": ["supabase", "vercel"],
      "skills": ["supabase", "supabase-postgres-best-practices", "backend-express"],
      "learnings": ".agents/domains/api/learnings"
    },
    {
      "id": "backend-express",
      "name": "Backend Express Agent",
      "path": ".agents/domains/backend-express",
      "jurisdiction": {
        "allow_globs": ["backend/**"],
        "deny_globs": ["src/**", "scripts/**", ".github/**"]
      },
      "mcps": ["supabase"],
      "skills": ["backend-express"],
      "learnings": ".agents/domains/backend-express/learnings",
      "note": "Active only if backend/ exists; otherwise prefer api agent for src/app/api"
    },
    {
      "id": "seo",
      "name": "SEO & Crawlability Agent",
      "path": ".agents/domains/seo",
      "jurisdiction": {
        "allow_globs": [
          "src/lib/seo*",
          "src/components/JsonLd*",
          "src/components/PageMeta*",
          "src/app/**/page.tsx",
          "src/app/**/layout.tsx",
          "scripts/generate-sitemap*",
          "public/robots.txt",
          "public/**/sitemap*",
          "src/app/robots*",
          "src/app/sitemap*"
        ],
        "deny_globs": [
          "src/app/api/**",
          ".github/**",
          "scripts/!(generate-sitemap*)"
        ]
      },
      "mcps": [],
      "skills": ["seo-audit", "ai-seo"],
      "learnings": ".agents/domains/seo/learnings"
    },
    {
      "id": "content-market",
      "name": "Content & Market Pages Agent",
      "path": ".agents/domains/content-market",
      "jurisdiction": {
        "allow_globs": [
          "src/views/**",
          "src/data/**",
          "src/components/LeadForm*",
          "src/components/MarketPage*",
          "src/components/*Cta*",
          "src/components/*Booking*",
          "src/app/residential/**",
          "src/app/commercial/**",
          "src/app/service-area*/**",
          "src/app/painting-services/**",
          "src/app/contact/**",
          "src/app/estimate/**",
          "src/app/about/**",
          "src/app/projects/**"
        ],
        "deny_globs": [
          "src/app/api/**",
          "src/components/ui/**",
          ".github/**",
          "scripts/**"
        ]
      },
      "mcps": [],
      "skills": ["copywriting", "cro", "site-architecture"],
      "learnings": ".agents/domains/content-market/learnings"
    },
    {
      "id": "ci-devops",
      "name": "CI/CD & DevOps Agent",
      "path": ".agents/domains/ci-devops",
      "jurisdiction": {
        "allow_globs": [
          ".github/**",
          ".husky/**",
          "vercel.json",
          "knip.json",
          ".markdownlint*",
          "scripts/ci*",
          "scripts/pr-*.mjs",
          "scripts/normalize-branch*",
          "scripts/verify-vercel*",
          "scripts/enforce-*.js",
          "scripts/compile.js",
          "package.json"
        ],
        "deny_globs": [
          "src/**",
          "backend/**"
        ]
      },
      "mcps": ["github", "vercel"],
      "skills": ["deployments-cicd", "env-vars", "vercel-cli"],
      "learnings": ".agents/domains/ci-devops/learnings"
    },
    {
      "id": "agent-os",
      "name": "Agent OS & Learning Agent",
      "path": ".agents/domains/agent-os",
      "jurisdiction": {
        "allow_globs": [
          ".agents/**",
          "scripts/agent-os*",
          "scripts/learn*",
          "scripts/evolve*",
          "scripts/evaluate*",
          "scripts/learning-loop*",
          "scripts/entire*",
          "scripts/graph-context*",
          "scripts/hooks/**",
          "scripts/domain-agent*",
          "scripts/turso*",
          ".learnings/**",
          "graphify-out/**",
          ".graphifyignore",
          "AGENTS.md",
          "CLAUDE.md"
        ],
        "deny_globs": [
          "src/**",
          "backend/**",
          "public/**"
        ]
      },
      "mcps": [],
      "skills": ["skill-evaluator", "entire", "entire-search", "graphify"],
      "learnings": ".agents/domains/agent-os/learnings"
    }
  ]
}
